# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 공공데이터 ────────────────────────────────────────────────────────────────
DATA_GO_KR_SERVICE_KEY=          # data.go.kr 디코딩 키

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_URL=jdbc:postgresql://postgres:5432/realestate
POSTGRES_USER=realestate
POSTGRES_PASSWORD=realestate

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://realestate:realestate@rabbitmq:5672/

# ── Agent Runtime ─────────────────────────────────────────────────────────────
AGENT_MAX_STEPS=20
AGENT_BUDGET_TOKENS=200000
AGENT_TIMEOUT_SEC=120

# ── Phase 1.5 (Watch + 주간 다이제스트) — Epic A에서는 미사용 ─────────────────
# WATCH_SCHEDULE_CRON=0 0 9 * * FRI
# WATCH_REFRESH_MONTHS=2
# DIGEST_PRICE_DELTA_PCT=3
# DIGEST_VOLUME_DELTA_PCT=50
